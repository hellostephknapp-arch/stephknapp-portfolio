---
// Replace YOUR_FORM_ID with your Formspree form ID (formspree.io → New form).
const FORMSPREE_ENDPOINT = 'https://formspree.io/f/YOUR_FORM_ID';
---
<section id="contact" class="section contact">
  <div class="container contact__inner">
    <div class="contact__intro">
      <p class="eyebrow">Let's work together</p>
      <h2 class="contact__title">I'm taking on new projects.</h2>
      <p class="contact__lead">
        Get in touch if you have something in mind.
      </p>
    </div>

    <form
      class="contact__form"
      action={FORMSPREE_ENDPOINT}
      method="POST"
    >
      <div class="field">
        <label class="field__label" for="name">Name</label>
        <input class="field__input" type="text" id="name" name="name" required autocomplete="name" />
      </div>

      <div class="field">
        <label class="field__label" for="email">Email</label>
        <input class="field__input" type="email" id="email" name="email" required autocomplete="email" />
      </div>

      <div class="field">
        <label class="field__label" for="project">What do you have in mind?</label>
        <textarea class="field__input" id="project" name="message" rows="5" required></textarea>
      </div>

      <!-- Honeypot for spam bots -->
      <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" class="visually-hidden" aria-hidden="true" />

      <button type="submit" class="btn btn--primary contact__submit">Send message</button>
      <p class="contact__fallback">
        Prefer email? Reach me at
        <a href="mailto:hello@stephknapp.com">hello@stephknapp.com</a>.
      </p>
    </form>
  </div>
</section>

<style>
  .contact {
    background-color: var(--color-primary);
    color: #fff;
  }

  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 6vw, 5rem);
    align-items: start;
  }

  .contact .eyebrow {
    color: #d9c7ce;
  }

  .contact__title {
    color: #fff;
    font-size: clamp(2rem, 4.5vw, 3rem);
    margin-bottom: 1rem;
  }

  .contact__lead {
    font-family: var(--font-body);
    font-size: clamp(1.3rem, 2.4vw, 1.6rem);
    color: rgba(255, 255, 255, 0.88);
    margin-bottom: 0;
    max-width: 34ch;
  }

  .contact__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field__label {
    font-family: var(--font-ui);
    font-size: 0.82rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.85);
  }

  .field__input {
    font-family: var(--font-body);
    font-size: 1.15rem;
    color: var(--color-text);
    background-color: var(--color-bg);
    border: 1px solid transparent;
    padding: 0.85rem 1rem;
    width: 100%;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }

  .field__input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(217, 199, 206, 0.4);
  }

  textarea.field__input {
    resize: vertical;
    min-height: 7rem;
  }

  .contact__submit {
    background-color: var(--color-accent);
    align-self: flex-start;
    margin-top: 0.25rem;
  }

  .contact__submit:hover {
    background-color: var(--color-accent-dark);
  }

  .contact__fallback {
    font-family: var(--font-ui);
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.75);
    margin: 0.5rem 0 0;
  }

  .contact__fallback a {
    color: #fff;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media (max-width: 780px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
