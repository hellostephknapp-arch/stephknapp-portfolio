---
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container site-footer__inner">
    <span class="site-footer__name">Steph Knapp</span>
    <span class="site-footer__meta">B2B SaaS Content Writer · © {year}</span>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    padding-block: 2rem;
  }

  .site-footer__inner {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
    font-family: var(--font-ui);
  }

  .site-footer__name {
    font-weight: 700;
    font-size: 1rem;
    color: var(--color-text);
  }

  .site-footer__meta {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
